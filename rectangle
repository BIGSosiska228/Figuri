#pragma once
#include "Shape.h"

class Rectangle : public Shape
{
private:
    unsigned int width;
    unsigned int height;

public:
    Rectangle(unsigned int x, unsigned int y, unsigned int w, unsigned int h)
        : Shape(x,y)
    {
        width = w;
        height = h;
    }

    Rectangle(const Rectangle& source) : Shape(source)
    {
        width = source.width;
        height = source.height;
    }

    Shape* clone() override
    {
        return new Rectangle(*this);
    }

    void Draw() override
    {
        std::cout << "Rectangle "
                  << x << " "
                  << y << " "
                  << width << " "
                  << height << std::endl;
    }
};
